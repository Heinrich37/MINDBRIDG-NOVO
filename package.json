{
  "name": "mindbridge-mvp",
  "private": true,
  "version": "0.1.0",
  "description": "MindBridge MVP para acolhimento inicial e encaminhamento humano no Senac.",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:backend dev:frontend",
    "dev:frontend": "npm --workspace frontend run dev",
    "dev:backend": "npm --workspace backend run dev",
    "build": "npm --workspace frontend run build",
    "start": "npm --workspace backend run start",
    "lint": "npm --workspace frontend run lint"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  }
}
